generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}

model Entrada {
  id_entrada    BigInt   @id
  id_pedido     Int      @unique
  nombre_evento String
  cantidad      Int
  estado        String
  creado        DateTime @default(now())
  id_usuario    String
}

